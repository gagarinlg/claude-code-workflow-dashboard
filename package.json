{
  "name": "claude-code-workflow-dashboard",
  "displayName": "Claude Code Workflow Dashboard",
  "description": "Live dashboard for Claude Code workflow runs — loop & agent overview, per-agent output, and review findings, updated in real time. Unofficial community tool, not affiliated with Anthropic.",
  "version": "1.0.0",
  "publisher": "malte-langermann",
  "author": {
    "name": "Malte Langermann",
    "email": "malte@langermann.net"
  },
  "license": "GPL-3.0-or-later",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.84.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "node scripts/typecheck.mjs",
    "lint": "eslint --no-error-on-unmatched-pattern src test build.mjs scripts",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "make-fixture": "node scripts/make-sample-run.mjs",
    "prescreenshots": "node -e \"require('playwright')\" 2>/dev/null && node -e \"const {chromium}=require('playwright');chromium.executablePath()&&process.exit(0);process.exit(1)\" 2>/dev/null || (echo 'Playwright Chromium not installed. Run: npx playwright install chromium' && exit 1)",
    "screenshots": "node scripts/screenshot.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "~1.84.0",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.0",
    "eslint-plugin-security": "^4.0.1",
    "playwright": "^1.61.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "workflow",
    "agents",
    "dashboard",
    "orchestration",
    "monitor"
  ],
  "galleryBanner": {
    "color": "#1b1916",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gagarinlg/claude-code-workflow-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/gagarinlg/claude-code-workflow-dashboard/issues"
  },
  "homepage": "https://github.com/gagarinlg/claude-code-workflow-dashboard#readme",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeWorkflow",
          "title": "Claude Code Workflow Dashboard",
          "icon": "media/activity.svg"
        }
      ]
    },
    "views": {
      "claudeWorkflow": [
        {
          "id": "claudeWorkflow.dashboard",
          "name": "Dashboard",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeWorkflow.open",
        "title": "Open Dashboard in Editor",
        "category": "Claude Code Workflow",
        "icon": "$(window)"
      },
      {
        "command": "claudeWorkflow.focus",
        "title": "Show Dashboard",
        "category": "Claude Code Workflow",
        "icon": "$(pulse)"
      },
      {
        "command": "claudeWorkflow.refresh",
        "title": "Refresh",
        "category": "Claude Code Workflow",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeWorkflow.openGuide",
        "title": "Open Workflow Authoring Guide",
        "category": "Claude Code Workflow",
        "icon": "$(book)"
      },
      {
        "command": "claudeWorkflow.selectRun",
        "title": "Select Workflow Run…",
        "category": "Claude Code Workflow",
        "icon": "$(list-unordered)"
      },
      {
        "command": "claudeWorkflow.exportMarkdown",
        "title": "Export Run as Markdown…",
        "category": "Claude Code Workflow",
        "icon": "$(export)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeWorkflow.selectRun",
          "when": "view == claudeWorkflow.dashboard",
          "group": "navigation@1"
        },
        {
          "command": "claudeWorkflow.openGuide",
          "when": "view == claudeWorkflow.dashboard",
          "group": "navigation@2"
        },
        {
          "command": "claudeWorkflow.open",
          "when": "view == claudeWorkflow.dashboard",
          "group": "navigation@3"
        },
        {
          "command": "claudeWorkflow.refresh",
          "when": "view == claudeWorkflow.dashboard",
          "group": "navigation@4"
        },
        {
          "command": "claudeWorkflow.exportMarkdown",
          "when": "view == claudeWorkflow.dashboard",
          "group": "navigation@5"
        }
      ]
    },
    "keybindings": [
      {
        "command": "claudeWorkflow.focus",
        "key": "ctrl+alt+w",
        "mac": "cmd+alt+w"
      }
    ],
    "configuration": {
      "title": "Claude Code Workflow Dashboard",
      "properties": {
        "claudeWorkflow.workflowsGlobBase": {
          "type": "string",
          "default": "",
          "markdownDescription": "Base directory searched recursively for the newest `wf_*` workflow run. Leave empty to use `~/.claude/projects` (auto-discovers the most recent run across all projects)."
        },
        "claudeWorkflow.repoDir": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional repository path; when set, the **Changed** tab shows files recently touched there (within the last 15 minutes). Leave empty to use the first open workspace folder."
        },
        "claudeWorkflow.refreshMs": {
          "type": "number",
          "default": 4000,
          "minimum": 1000,
          "description": "Fallback polling interval in milliseconds (minimum 1000). Changes take effect on the next polling tick — no reload needed. The dashboard also refreshes immediately on file-system changes."
        },
        "claudeWorkflow.statusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show a live status-bar item with the current workflow phase and agent counts. Click it to open the dashboard."
        },
        "claudeWorkflow.roleRules": {
          "type": "array",
          "default": [],
          "markdownDescription": "Optional rules to label agents per workflow: an array of `{ \"re\": \"<regex>\", \"label\": \"<name>\", \"key\": \"<id>\" }`. Each rule matches against an agent's first prompt. Without rules, labels are derived automatically from each prompt (\"You are a …\").",
          "items": {
            "type": "object",
            "properties": {
              "re": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "key": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
